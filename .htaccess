<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Custom URL Mappings - What you see in address bar
    RewriteRule ^index/?$ index.html [L]
    RewriteRule ^mission-vision/?$ mission-vision.html [NC,L]
    RewriteRule ^service-hours/?$ service-hours.html [NC,L]
    RewriteRule ^library-personel/?$ library-personnel.html [NC,L]
    RewriteRule ^policies-rules/?$ policies-rules.html [NC,L]
    RewriteRule ^citizens-charter/?$ citizens-charter.html [NC,L]
    RewriteRule ^linkages/?$ linkages.html [NC,L]
    RewriteRule ^libraries/?$ libraries.html [NC,L]
    RewriteRule ^tabango-campus-library/?$ tabango-campus-library.html [NC,L]
    RewriteRule ^book-borrowing/?$ book-borrowing.html [NC,L]
    RewriteRule ^digital-resources/?$ digital-resources.html [NC,L]
    RewriteRule ^database/?$ database.html [NC,L]
    RewriteRule ^courses/?$ courses.html [NC,L]
    RewriteRule ^repository/?$ repository.html [NC,L]
    
    # Remove .html extension
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([a-zA-Z0-9_/-]+)/?$ $1.html [NC,L]
</IfModule>